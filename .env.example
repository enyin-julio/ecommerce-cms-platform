# Required in all environments.
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/ecommerce_cms"
SESSION_SECRET="replace-with-a-unique-random-secret-at-least-32-characters"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NODE_ENV="development"
# Use "local" for local development or "vercel-blob" for production media uploads.
# Vercel Blob projects should use Vercel-managed OIDC env vars when connected in Vercel.
STORAGE_PROVIDER="local"
# Optional legacy fallback token for older Vercel Blob setups.
BLOB_READ_WRITE_TOKEN=""

# Backward-compatible alias. Prefer SESSION_SECRET for new environments.
COOKIE_SECRET=""
NEXTAUTH_SECRET=""

# Optional local SQLite fallback for development only.
SQLITE_DATABASE_URL="file:./dev.db"

# Reserved for future infrastructure integrations.
REDIS_URL=""
ELASTICSEARCH_URL=""

# Production safety valve. Keep false unless intentionally seeding a disposable environment.
ALLOW_PRODUCTION_SEED="false"

# Payment integration.
# Waiting-for-production-account mode:
# - Use ECPay sandbox mode while the official ECPay production merchant account is not approved.
# - Keep production credentials empty in examples.
# - Never put production payment keys in local examples or commits.
PAYMENT_PROVIDER="ecpay"
PAYMENT_MODE="sandbox"
ENABLE_ECPAY_PRODUCTION="false"
STRIPE_TEST_SECRET_KEY=""
ECPAY_MERCHANT_ID=""
ECPAY_HASH_KEY=""
ECPAY_HASH_IV=""
ECPAY_RETURN_URL="http://localhost:3000/api/payments/ecpay/webhook"
ECPAY_CLIENT_BACK_URL="http://localhost:3000/account/orders"
ECPAY_ORDER_RESULT_URL="http://localhost:3000/checkout/success"
ECPAY_REFUND_NOTIFY_URL="http://localhost:3000/api/payments/ecpay/refund-webhook"
ECPAY_REFUND_API_ENABLED="false"
NEWEBPAY_TEST_MERCHANT_ID=""
LINE_PAY_TEST_CHANNEL_ID=""
